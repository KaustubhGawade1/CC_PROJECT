# EC2 Deployment Environment
# Copy this to .env.prod and replace with your actual EC2 public IP or domain

# Database Configuration
DB_USER=myuser
DB_PASSWORD=mypassword
DB_NAME=mydb

# Backend Configuration
HIBERNATE_DDL=update
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# CORS Configuration - Replace with your EC2 instance
# Option 1: Use EC2 Public IP
APP_CORS_ALLOWED_ORIGINS=http://52.34.123.45,https://52.34.123.45,http://your-domain.com,https://your-domain.com

# Frontend Configuration - Replace with your EC2 instance
# Option 1: Use EC2 Public IP
VITE_BACK_END_URL=http://52.34.123.45:8080

# Option 2: Use Domain Name (if you have one)
# VITE_BACK_END_URL=http://your-domain.com:8080
# APP_CORS_ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com
