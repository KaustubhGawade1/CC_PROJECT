# EC2 Environment Configuration (.env.prod)
# Copy this to .env on your EC2 instance and update values

# ============================================
# Database Configuration
# ============================================
DB_USER=myuser
DB_PASSWORD=change_this_to_strong_password
DB_NAME=mydb

# ============================================
# Backend Configuration
# ============================================
# IMPORTANT: Use 'update' or 'validate' for production (NOT 'create')
# - create: drops and recreates tables (data loss!)
# - update: adds new columns/tables without dropping
# - validate: only validates schema (safest)
HIBERNATE_DDL=update

STRIPE_SECRET_KEY=sk_live_your_actual_stripe_key_here

# ============================================
# CORS Configuration (EC2 IPs)
# ============================================
# Replace with your actual EC2 public IPs or domain names
# Format: protocol://IP:port or protocol://domain
# Include both HTTP and HTTPS if applicable

# Option 1: Using EC2 Public IPs
APP_CORS_ALLOWED_ORIGINS=http://13.60.86.187:3000,https://13.60.86.187:3000,http://13.49.223.238,https://13.49.223.238

# Option 2: Using Domain Names (recommended for production)
# APP_CORS_ALLOWED_ORIGINS=http://frontend.yourapp.com,https://frontend.yourapp.com,http://api.yourapp.com,https://api.yourapp.com

# Option 3: Mix of IPs and Domains
# APP_CORS_ALLOWED_ORIGINS=http://13.60.86.187:3000,https://yourapp.com,http://api.yourapp.com

# ============================================
# Frontend Configuration
# ============================================
# Point to EC2 backend IP or domain
# This is used during Docker build for frontend

# Option 1: Using EC2 Backend Public IP
VITE_BACK_END_URL=http://13.49.223.238:8080

# Option 2: Using Domain (recommended)
# VITE_BACK_END_URL=http://api.yourapp.com:8080
# or if behind load balancer:
# VITE_BACK_END_URL=https://api.yourapp.com
